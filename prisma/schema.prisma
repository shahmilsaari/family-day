generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model FamilyDayEvent {
  id            Int      @id @default(autoincrement())
  title         String
  year          Int      @unique
  location      String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teams Team[]
  games Game[]
  scores Score[]
  timetable TentativeSchedule[]

  @@map("family_day_events")
}

model TentativeSchedule {
  id        Int      @id @default(autoincrement())
  eventId   Int
  scheduleDate DateTime?
  time      String
  title     String
  pic       String?
  location  String?
  notes     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("tentative_schedules")
}

model Team {
  id           Int           @id @default(autoincrement())
  eventId      Int
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  event        FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  scores       Score[]

  @@unique([eventId, name])
  @@map("teams")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId    Int
  name      String
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

model Game {
  id           Int           @id @default(autoincrement())
  eventId      Int
  name         String
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  event        FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scores       Score[]

  @@unique([eventId, name])
  @@map("games")
}

model Score {
  id        Int      @id @default(autoincrement())
  eventId   Int
  teamId    Int
  gameId    Int
  points    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  game      Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([teamId, gameId])
  @@map("scores")
}
