generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events   FamilyDayEvent[]
  sessions Session[]

  @@map("users")
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model FamilyDayEvent {
  id            Int      @id @default(autoincrement())
  userId        Int
  title         String
  year          Int
  location      String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  teams Team[]
  games Game[]
  scores Score[]
  timetable TentativeSchedule[]

  @@unique([userId, year])
  @@map("family_day_events")
}

model TentativeSchedule {
  id        Int      @id @default(autoincrement())
  eventId   Int
  scheduleDate DateTime?
  time      String
  title     String
  pic       String?
  location  String?
  notes     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("tentative_schedules")
}

model Team {
  id           Int           @id @default(autoincrement())
  eventId      Int
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  event        FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  scores       Score[]

  @@unique([eventId, name])
  @@map("teams")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId    Int
  name      String
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

model Game {
  id           Int           @id @default(autoincrement())
  eventId      Int
  name         String
  description  String?
  includeInScore Boolean     @default(true)
  order        Int           @default(0)
  rounds       Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  event        FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scores       Score[]

  @@unique([eventId, name])
  @@map("games")
}

model Score {
  id        Int      @id @default(autoincrement())
  eventId   Int
  teamId    Int
  gameId    Int
  round     Int      @default(1)
  points    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     FamilyDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  game      Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([teamId, gameId, round])
  @@map("scores")
}
